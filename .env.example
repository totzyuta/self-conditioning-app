# Optional: absolute origin for `/api/v2/state` when running inside Capacitor iOS/Android
# (the bundled app has no same-origin server). Example: https://your-deployment.vercel.app
# Do not add a trailing slash. Required for `npm run cap:sync` (or pass inline in the shell).
# VITE_API_BASE_URL=https://your-app.vercel.app

# Optional: for `npm run verify:sync-api` only — same value as the server’s SYNC_PASSWORD (never commit a real value).
# SYNC_PASSWORD=

# Optional: user_id query for verify:sync-api (default totzyu_dev)
# VERIFY_USER_ID=totzyu_dev
