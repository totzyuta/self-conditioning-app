{
  "name": "ond-app",
  "version": "1.0.1",
  "description": "ond — personal health log",
  "type": "module",
  "scripts": {
    "brand:raster": "node scripts/raster-ond-assets.mjs",
    "build": "vite build",
    "cap:sync": "npm run build && npx cap sync ios",
    "dev": "vite",
    "dev:vite": "vite --port $PORT",
    "dev:vercel": "vercel dev",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "db:dump:prod": "bash scripts/dump-prod-db.sh"
  },
  "dependencies": {
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.3.1",
    "@capacitor/ios": "^8.3.1",
    "@supabase/supabase-js": "^2.103.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.1",
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "sharp": "^0.34.5",
    "typescript": "^5.4.5",
    "vercel": "^51.2.1",
    "vite": "^5.2.10"
  }
}
